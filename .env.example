# PromptCard-Manager environment variables

# Development server
VITE_PORT=3000

# Development-only API proxy
VITE_API_PROXY_TARGET=https://ark.cn-beijing.volces.com/api/coding/v3

# AI service defaults
VITE_DEFAULT_AI_ENABLED=true
VITE_DEFAULT_AI_PROVIDER=deepseek
VITE_DEFAULT_AI_API_BASE=/api
VITE_DEFAULT_AI_API_KEY=replace-with-local-key
VITE_DEFAULT_AI_MODEL=deepseek-v3.2
VITE_DEFAULT_AI_MAX_TOKENS=4000
VITE_DEFAULT_AI_TEMPERATURE=0.3

# Build options
VITE_BUILD_MINIFY=true
VITE_BUILD_SOURCE_MAP=false

# App metadata
VITE_APP_TITLE=PromptCard-Manager - Video Prompt Builder
VITE_APP_DESCRIPTION=Video prompt builder with evaluation and optimization suggestions
