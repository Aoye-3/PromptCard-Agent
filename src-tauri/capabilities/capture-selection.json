{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "capture-selection-capability",
  "description": "Allow the native screenshot selection window to finish or cancel its active capture session.",
  "windows": ["capture-selection"],
  "remote": {
    "urls": ["http://127.0.0.1:*", "http://localhost:*"]
  },
  "permissions": [
    "core:event:allow-emit-to",
    "native-screenshot-selection"
  ]
}
