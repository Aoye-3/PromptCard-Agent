<!doctype html>
<html>
<head>
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>PromptCard Manager</title>
  <hta:application
    id="PromptCardLaunchSplash"
    applicationname="PromptCard Manager"
    border="none"
    caption="no"
    contextmenu="no"
    maximizebutton="no"
    minimizebutton="no"
    scroll="no"
    showintaskbar="no"
    singleinstance="no"
    sysmenu="no"
    windowstate="normal"
  />
  <style>
    html,
    body {
      width: 100%;
      height: 100%;
      margin: 0;
      overflow: hidden;
      background: #f8f7f2;
      color: #171715;
      font-family: "Segoe UI", Arial, sans-serif;
      border-radius: 14px;
    }

    .shell {
      box-sizing: border-box;
      width: 100%;
      height: 100%;
      padding: 28px 30px;
      border: 1px solid #e5e0d4;
      box-shadow: 0 18px 50px rgba(20, 20, 19, 0.16);
    }

    .brand {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 18px;
    }

    .row {
      display: flex;
      align-items: center;
      gap: 14px;
      color: #55534d;
      font-size: 13px;
      line-height: 1.45;
    }

    .spinner {
      width: 24px;
      height: 24px;
      border: 3px solid #e3dfd3;
      border-top-color: #c96442;
      border-radius: 50%;
      animation: spin 850ms linear infinite;
      flex: none;
    }

    .bar {
      position: relative;
      height: 3px;
      margin-top: 24px;
      overflow: hidden;
      background: #e5e0d4;
    }

    .bar:before {
      content: "";
      position: absolute;
      inset: 0 auto 0 0;
      width: 42%;
      background: #c96442;
      animation: progress 1200ms ease-in-out infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    @keyframes progress {
      0% { transform: translateX(-110%); }
      100% { transform: translateX(260%); }
    }
  </style>
  <script type="text/javascript">
    window.resizeTo(420, 190);
    window.moveTo(
      Math.max(0, (screen.availWidth - 420) / 2),
      Math.max(0, (screen.availHeight - 190) / 2)
    );
  </script>
</head>
<body>
  <div class="shell">
    <div class="brand">PromptCard Manager</div>
    <div class="row">
      <div class="spinner"></div>
      <div>
        Starting local services and opening the desktop shell...
      </div>
    </div>
    <div class="bar"></div>
  </div>
</body>
</html>
