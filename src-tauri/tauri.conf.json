{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PromptCard Manager Dev Shell",
  "version": "4.0.0",
  "identifier": "dev.promptcard.manager.shell",
  "build": {
    "beforeDevCommand": "npm.cmd run desktop:dev-services",
    "beforeBuildCommand": "npm.cmd run build",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PromptCard Manager Dev Shell",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "capture-toolbar",
        "title": "PromptCard Capture",
        "url": "/?window=capture-toolbar",
        "width": 228,
        "height": 64,
        "minWidth": 228,
        "minHeight": 64,
        "maxWidth": 228,
        "maxHeight": 64,
        "dragDropEnabled": false,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
